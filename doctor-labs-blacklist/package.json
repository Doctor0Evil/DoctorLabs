{
  "name": "doctor-labs-blacklist",
  "version": "1.0.0",
  "description": "Doctor-Labs Blacklist JavaScript Gateway - Edge middleware for AI-chat and AR/VR harassment filtering",
  "main": "src/filters/doctorLabsBlacklist.js",
  "types": "types/index.d.ts",
  "files": [
    "src/",
    "types/",
    "policies/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --watch src/ --exec node src/index.js",
    "build": "npm run lint && npm run test",
    "lint": "eslint src/ --ext .js --format stylish",
    "lint:fix": "eslint src/ --ext .js --fix",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=html --coverageReporters=text",
    "test:integration": "jest --config jest.integration.config.js",
    "benchmark": "node benchmarks/harassment_detection.bench.js",
    "docs": "jsdoc -c jsdoc.json -r src/ -d docs/",
    "docs:serve": "http-server docs/ -p 8080",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "postinstall": "node scripts/postinstall.js",
    "security:audit": "npm audit --audit-level=high",
    "security:fix": "npm audit fix",
    "compliance:check": "node scripts/compliance-check.js",
    "version:info": "node scripts/version-info.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doctor-labs/blacklist.git"
  },
  "keywords": [
    "neurorights",
    "harassment-detection",
    "bci",
    "xr",
    "ar",
    "vr",
    "ai-safety",
    "content-filtering",
    "capability-safety",
    "doctor-labs",
    "aln-nanonet",
    "eu-ai-act"
  ],
  "author": {
    "name": "Doctor-Labs Research Division",
    "email": "research@doctor-labs.io",
    "url": "https://doctor-labs.io"
  },
  "contributors": [
    {
      "name": "Doctor0Evil",
      "email": "doctor0evil@doctor-labs.io",
      "url": "https://github.com/doctor0evil"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/doctor-labs/blacklist/issues",
    "email": "support@doctor-labs.io"
  },
  "homepage": "https://github.com/doctor-labs/blacklist#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "dependencies": {
    "uuid": "^9.0.0",
    "node-fetch": "^2.7.0",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "rate-limiter-flexible": "^4.0.1",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "validator": "^13.11.0",
    "sanitize-html": "^2.11.0",
    "crypto-js": "^4.2.0",
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-security": "^2.1.0",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "nock": "^13.4.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.2",
    "jsdoc": "^4.0.2",
    "ink-docstrap": "^1.3.2",
    "http-server": "^14.1.1",
    "benchmark": "^2.1.4",
    "microtime": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "commitlint": "^18.4.3",
    "semantic-release": "^22.0.12",
    "npm-audit-ci-wrapper": "^3.0.2",
    "snyk": "^1.1260.0"
  },
  "peerDependencies": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3",
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.3"
  },
  "config": {
    "rustCoreEndpoint": "http://localhost:8080",
    "rustCoreTimeout": 5000,
    "capabilityModePollInterval": 10000,
    "logLevel": "info",
    "logFormat": "json",
    "evidenceBundleEndpoint": "/api/v1/evidence/submit",
    "capabilityModeEndpoint": "/api/v1/capability/mode",
    "sessionTokenHeader": "X-DoctorLabs-Session-Token",
    "userDidHeader": "X-DoctorLabs-User-DID",
    "nodeIdHeader": "X-DoctorLabs-Node-ID"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "jest --findRelatedTests",
      "git add"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "build",
          "ci",
          "chore",
          "revert",
          "security",
          "compliance"
        ]
      ],
      "subject-case": [
        2,
        "never",
        [
          "sentence-case",
          "start-case",
          "pascal-case",
          "upper-case"
        ]
      ],
      "header-max-length": [
        2,
        "always",
        72
      ]
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/",
      "/build/"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/bin/**/*.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "verbose": true,
    "silent": false
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "extends": [
      "airbnb-base",
      "plugin:security/recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "max-len": [
        "warn",
        {
          "code": 120,
          "ignoreUrls": true,
          "ignoreStrings": true
        }
      ],
      "security/detect-object-injection": "warn",
      "security/detect-non-literal-fs-filename": "warn",
      "security/detect-possible-timing-attacks": "warn"
    },
    "ignorePatterns": [
      "node_modules/",
      "dist/",
      "build/",
      "coverage/",
      "docs/",
      "benchmarks/"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "bracketSpacing": true,
    "arrowParens": "always"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-push": "npm run test && npm run lint"
    }
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "develop",
        "prerelease": true
      }
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/changelog"
    ]
  },
  "funding": {
    "type": "organization",
    "url": "https://doctor-labs.io/funding"
  },
  "support": {
    "email": "support@doctor-labs.io",
    "url": "https://github.com/doctor-labs/blacklist/issues",
    "docs": "https://docs.doctor-labs.io/blacklist"
  },
  "compliance": {
    "frameworks": [
      "ALN-NanoNet HyperSafe Construct",
      "EU AI Act Article 15",
      "Neurorights Framework v2.1",
      "IEEE P7000 Series",
      "GDPR Article 22"
    ],
    "auditRetentionDays": 2555,
    "dataClassification": "HighlySensitive",
    "jurisdiction": "EU",
    "certifications": [
      "ALN-NanoNet HyperSafe Construct Certified",
      "EU AI Act High-Risk Compliant"
    ]
  },
  "security": {
    "auditLevel": "high",
    "vulnerabilityScanning": true,
    "dependencyChecking": true,
    "codeSigning": true,
    "supplyChainVerification": true,
    "sbomGenerated": true,
    "contact": "security@doctor-labs.io"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "private": false,
  "workspaces": [
    "packages/*"
  ]
}
